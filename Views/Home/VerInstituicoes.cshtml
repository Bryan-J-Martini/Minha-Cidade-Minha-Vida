@model List<MCMV.Models.UserViewModel>

@{
    ViewData["Title"] = "Instituições Cadastradas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    @* Barra de Pesquisa *@
    <div style="display: flex; justify-content: center; margin: 30px 0;">
        <div class="search-bar" style="background-color: #00a878; border-radius: 25px; padding: 10px 20px; width: 60%; display: flex; align-items: center;">
            <input type="text" id="inputPesquisa" placeholder="Pesquisar Instituição" style="background: transparent; border: none; color: white; width: 100%; outline: none;">
            <span style="color: white;">🔍</span>
        </div>
    </div>

    @* Listagem Dinâmica *@
    <div id="listaInstituicoes" style="padding: 0 50px;">
        @if (Model != null && Model.Any())
        {
            foreach (var inst in Model)
            {
                <div class="inst-card-item" style="border-bottom: 1px solid #eee; padding: 15px;">

                    <h4 class="nome-inst" style="color: #00A878; display: flex; align-items: center; gap: 8px; margin: 0 0 5px 0;">
                        @inst.Nome

                        @if (inst.IsVerificada)
                        {
                            <span title="Instituição Verificada" style="background-color: #1DA1F2; color: white; border-radius: 50%; width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-family: sans-serif; font-weight: bold; border: 1px solid #1DA1F2;">
                                ✓
                            </span>
                        }
                    </h4>
                    <p style="margin: 2px 0;">CNPJ: @inst.Documento</p>
                    <p style="margin: 2px 0; font-size: 0.9rem; color: #00A878;">
                        📧 @inst.Email
                    </p>
                </div>
            }
        }
        else
        {
            <p style="text-align: center; color: #999;">Nenhuma instituição encontrada.</p>
        }
    </div>
</div>

<style>
    /* Centralização da Barra de Pesquisa */
    .search-bar-container {
        display: flex;
        justify-content: center;
        margin: 40px 0;
    }

    .search-bar {
        background-color: #00C08B;
        border-radius: 50px;
        padding: 10px 30px;
        display: flex;
        align-items: center;
        width: 60%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

        .search-bar input {
            background: transparent;
            border: none;
            color: white;
            font-size: 20px;
            width: 100%;
            outline: none;
        }

            .search-bar input::placeholder {
                color: rgba(255,255,255,0.8);
            }

    .search-icon {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    /* Grid de 4 Colunas */
    .instituicoes-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
        padding: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .instituicao-item {
        font-family: sans-serif;
        font-size: 14px;
        line-height: 1.6;
        color: #333;
    }

    .inst-nome {
        font-size: 16px;
        margin-bottom: 5px;
    }

    .inst-detalhes, .inst-endereco {
        display: flex;
        justify-content: space-between;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const input = document.getElementById('inputPesquisa');
        const itens = document.getElementsByClassName('inst-card-item');

        input.addEventListener('input', function () {
            const termo = input.value.toLowerCase().trim();

            Array.from(itens).forEach(function (item) {
                const conteudo = item.textContent.toLowerCase();

                if (conteudo.includes(termo)) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        });
    });
</script>